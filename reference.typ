  caption: [Исходные данные для Задания 3]
)

== Расчёт — до внедрения ИТ (вариант 1)

*1. Трудоёмкость в месяцах*

$
T_1^"мес" = T_1^"час" / (Ч_"РД" times Ч_"РЧ") = 708 / (22 times 8) = 708 / 176 approx 4","023 text(" мес.")
$

*2. Годовые затраты на оплату труда*

$
З П_1 = O_С times T_1^"мес" times (1 + k_Д) times (1 + k_У)
$
$
З П_1 = 4 space 500 times 4","023 times 1","1 times 1","15 = bold(22 space 899","38) text(" руб.")
$

*3. Отчисления во внебюджетные фонды*

$
О Т_"вн1" = З П_1 times k_"ОВФ" = 22 space 899","38 times 0","302 = bold(6 space 915","61) text(" руб.")
$

*4. Затраты на эксплуатацию ЭВМ*

$
Z_"ЭВМ1" = T_1^"час" times k_Г times n times C_"М-Ч"
= 708 times 0","95 times 1 times 8 = bold(5 space 380","80) text(" руб.")
$

*5. Итоговые эксплуатационные затраты до внедрения*

$
C_1 = З П_1 + О Т_"вн1" + Z_"ЭВМ1" + M_З_1 + H_P_1
$
$
C_1 = 22 space 899","38 + 6 space 915","61 + 5 space 380","80 + 1 space 500","00 + 700","00 = bold(37 space 395","79) text(" руб.")
$

== Расчёт — после внедрения ИТ (вариант 2)

*1. Трудоёмкость в месяцах*

$
T_2^"мес" = 177 / (22 times 8) = 177 / 176 approx 1","006 text(" мес.")
$

*2. Годовые затраты на оплату труда*

$
З П_2 = 4 space 500 times 1","006 times 1","1 times 1","15 = bold(5 space 724","84) text(" руб.")
$

*3. Отчисления во внебюджетные фонды*

$
О Т_"вн2" = З П_2 times k_"ОВФ" = 5 space 724","84 times 0","302 = bold(1 space 728","90) text(" руб.")
$

*4. Затраты на эксплуатацию ЭВМ*

$
Z_"ЭВМ2" = 177 times 0","95 times 1 times 8 = bold(1 space 345","20) text(" руб.")
$

*5. Итоговые эксплуатационные затраты после внедрения*

$
C_2 = З П_2 + О Т_"вн2" + Z_"ЭВМ2" + M_З_2 + H_P_2
$
$
C_2 = 5 space 724","84 + 1 space 728","90 + 1 space 345","20 + 2 space 000","00 + 500","00 = bold(11 space 298","94) text(" руб.")
$

