    table.cell(colspan: 2, align: right)[*Итого $Z_"СПП"$:*], [*1 000,00*],
  ),
  caption: [Программные продукты специального назначения]
)

*6. Затраты на хозяйственно-операционные нужды*

#figure(
  table(
    columns: (auto, auto, auto, auto),
    align: (left, right, right, right),
    inset: 6pt,
    stroke: 0.5pt,
    table.header(
      [*Наименование*], [*Цена, руб.*], [*Кол-во, шт.*], [*Сумма, руб.*]
    ),
    [Диск CD-RW Digitex],   [25,00],  [1],   [25,00],
    [Дискета 3,5'' TDK],    [8,00],   [2],   [16,00],
    [Бумага (лист)],        [0,50],   [110], [55,00],
