  ),
  caption: [Затраты на хозяйственно-операционные нужды]
)

*7. Накладные расходы*

$
P_H = Z_"ФОТР" times k_"НР" = 13 space 282","50 times 0","30 = bold(3 space 984","75) text(" руб.")
$

*8. Итоговые затраты на разработку*

$
Z_"РПР" = Z_"ФОТР" + Z_"ОВФ" + Z_"ЭВМ" + Z_"СПП" + Z_"ХОН" + P_H
$
$
Z_"РПР" = 13 space 282","50 + 4 space 011","32 + 3 space 344","00 + 1 space 000","00 + 96","00 + 3 space 984","75
$
$
Z_"РПР" = bold(25 space 718","57) text(" руб.")
$

