    [Материальные затраты, руб.], [$M_З_1 = 1 space 500$], [$M_З_2 = 2 space 000$],
    [Накладные расходы, руб.], [$H_P_1 = 700$],       [$H_P_2 = 500$],
    [Рабочих дней в мес., $Ч_"РД"$], table.cell(colspan: 2)[22],
    [Рабочих часов в день, $Ч_"РЧ"$], table.cell(colspan: 2)[8],
    [$k_Д$], table.cell(colspan: 2)[0,10],
    [$k_У$], table.cell(colspan: 2)[0,15],
